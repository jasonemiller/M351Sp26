  </prefigure>
</image>
</figure>

</proof>


</section>

<section>
    <title>Consequences of Completeness</title>       

    <theorem>
        <title>Archimedean Properties</title>
        <statement>
            <ol>
                <li><p>Given any <m>x \in \mathbb{R}</m>, there is an <m>n \in \mathbb{N}</m> with <m>n &gt; x</m>.</p></li>
                <li><p>Given any <m>x \in \mathbb{R}</m> with <m>x>0</m>, there is an <m>n \in \mathbb{N}</m> with <m>\frac{1}{n} &lt; x</m>.</p></li>
            </ol>
        </statement>
    </theorem>

    <p workspace="9in"></p>


</section>

<section>
    <title>Consequences of Completeness</title>       

    <theorem>
        <title>Density of <m>\mathbb{Q}</m> in <m>\mathbb{R}</m></title>
        <statement>
            Let <m>a, b, \in \ mathbb{R}</m> with <m>a \neq b</m>.  Then there is an <m>r \in \mathbb{Q}</m> with <m>a &lt; r &lt; b</m>.
        </statement>
    </theorem>

    <p workspace="9in"></p>


</section>

<section>
    <title>Consequences of Completeness</title>       

    <theorem>
        <title>Density of <m>\mathbb{Q}</m> in <m>\mathbb{R}</m></title>
        <statement>
            Let <m>a, b \in \mathbb{R}</m> with <m>a \neq b</m>.  Then there is an <m>x \in \mathbb{Q}^c</m> with <m>a &lt; x &lt; b</m>.
        </statement>
    </theorem>

    <p workspace="9in"></p>


</section>

